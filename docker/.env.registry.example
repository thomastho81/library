# Copie para .env.registry e ajuste se fizer fork (dono/repo do GitHub).
# Uso: docker compose --env-file .env.registry -f docker-compose-app.registry.yml pull
#      docker compose --env-file .env.registry -f docker-compose-app.registry.yml up -d

